# --- Python / tooling (union of both source repos) ---
/.venv/
.venv/
/.idea/
.idea/
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.DS_Store

# --- Pretrained YOLO weights: auto-downloaded by Ultralytics on first use ---
models/pretrained/

# --- Ultralytics run outputs ---
runs/

# --- MNIST raw data: regenerable via torchvision datasets.MNIST(download=True) ---
# torchvision creates a MNIST/ subfolder under the root; here the root is datasets/mnist/.
datasets/mnist/MNIST/

# --- PPE training-run artifacts: regenerated by projects/3.1_ppe_detector_training.py ---
# best.pt is kept (loaded by the deploy script); everything else here is a throwaway output.
models/ppe_detector/*.png
models/ppe_detector/*.jpg
models/ppe_detector/results.csv
models/ppe_detector/args.yaml
models/ppe_detector/weights/last.pt

# --- PPE training dataset image splits (~163 MB): re-export from Roboflow Universe ---
# data.yaml + the Roboflow README files are kept as provenance; only the images are ignored.
datasets/construction_site_safety/train/
datasets/construction_site_safety/valid/
datasets/construction_site_safety/test/
